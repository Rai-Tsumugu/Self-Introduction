# Google Calendar
# 複数指定する場合はカンマ区切り。ラベルを付ける場合は "label:calendarId" 形式も可
# 例) GOOGLE_CALENDAR_IDS=personal:your.email@gmail.com,school:xxxx@group.calendar.google.com,project:yyyy@group.calendar.google.com
GOOGLE_CALENDAR_IDS=your.email@gmail.com
# サービスアカウント鍵JSON全体を1行に。GitHub Actions では secrets に格納
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# GitHub
GITHUB_USERNAME=Rai-Tsumugu
GITHUB_TOKEN=

# OpenAI 認証モード:
#   api-key       : OPENAI_API_KEY を使う標準方式（CI/cron向け）
#   chatgpt-oauth : ChatGPT サブスクのOAuthトークン (~/.codex/auth.json) を直接使い
#                   chatgpt.com/backend-api/codex/responses を呼ぶ（推奨・ローカル実行向け）
#   codex-cli     : codex CLI を子プロセスで呼ぶ（フォールバック）
OPENAI_AUTH_MODE=chatgpt-oauth

# api-key モード用
OPENAI_API_KEY=sk-...

# 共通: モデル名
#   api-key      -> 例: gpt-4o-mini
#   chatgpt-oauth-> 例: gpt-5-codex (ChatGPTサブスク枠で使えるモデル名)
OPENAI_MODEL=gpt-5-codex

# chatgpt-oauth モード用 (任意)
# CODEX_HOME=/Users/you/.codex            # 既定: ~/.codex
# CODEX_AUTH_PATH=/path/to/auth.json      # 直接指定したい場合

# codex-cli モード用 (任意)
# CODEX_CLI_BIN=codex

# データ書き込み先（既定: ../self-introduction/app/data）
DATA_DIR=
